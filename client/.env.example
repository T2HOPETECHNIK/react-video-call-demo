# Copy this file to "client/.env" and fill in real values for local dev.
# In production (Netlify/Vercel), set these in the host's dashboard instead.
#
# CRA only exposes variables that start with REACT_APP_.
# Restart `npm start` after changing any value.

# Deployed signaling server URL (leave blank locally to use localhost:5050)
REACT_APP_SERVER_URL=

# TURN credentials from your provider (e.g. metered.ca).
# The relay hostnames are hardcoded in src/context/Context.js (they're public);
# only these credentials are secret. Without them, calls use STUN only and
# may fail on strict/mobile networks.
REACT_APP_TURN_USERNAME=
REACT_APP_TURN_CREDENTIAL=
